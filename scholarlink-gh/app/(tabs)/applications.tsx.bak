import { useState } from "react";
import { useSafeAreaInsets } from "react-native-safe-area-context";
import { FlatList, StyleSheet, Text, View, Pressable, ScrollView, Platform, ImageBackground } from "react-native";
import { Ionicons } from "@expo/vector-icons";
import { router } from "expo-router";
import { useQuery } from "@tanstack/react-query";
import { useTrackers } from "../../hooks/useTracker";
import { useJobApplications } from "../../hooks/useJob";

import { Screen } from "../../components/Screen";
import { BaseScholarshipCard } from "../../components/BaseScholarshipCard";
import {
  EmptyState,
  ErrorState,
  LoadingState,
} from "../../components/StateView";
import { UserAvatar } from "../../components/UserAvatar";
import { colors } from "../../constants/colors";
import { documentService } from "../../services/documentService";
import { ApplicationTracker, JobApplication, UnifiedApplication } from "../../types/api";
import { getCountdownLabel, formatDeadline } from "../../utils/date";

type TabKey = 'in-progress' | 'submitted' | 'interview' | 'awarded' | 'rejected';
type TypeFilter = 'all' | 'scholarships' | 'jobs';

export default function ApplicationsScreen() {
  const insets = useSafeAreaInsets();
  const [activeTab, setActiveTab] = useState<TabKey>('in-progress');
  const [typeFilter, setTypeFilter] = useState<TypeFilter>('all');
  
  const { data: trackers = [], isLoading: loadingTrackers, error: errorTrackers, refetch: fetchTrackers } = useTrackers();
  const { data: jobApps = [], isLoading: loadingJobs, error: errorJobs, refetch: fetchJobs } = useJobApplications();
  const { data: documents = [] } = useQuery({
    queryKey: ['documents'],
    queryFn: () => documentService.getDocuments()
  });

  const loading = loadingTrackers || loadingJobs;
  const error = errorTrackers || errorJobs;

  const fetchAll = () => {
    fetchTrackers();
    fetchJobs();
  };

  // Merge into UnifiedApplication array
  const unifiedApplications: UnifiedApplication[] = [
    ...trackers.map((t): UnifiedApplication => ({
      type: 'scholarship',
      id: t.id,
      title: t.scholarshipName || `Scholarship #${t.scholarshipId}`,
      provider: t.scholarshipProvider || 'Provider unknown',
      status: t.status,
      deadline: t.scholarshipDeadline,
      updatedAt: t.updatedAt,
      linkId: t.scholarshipId,
      imageUrl: t.imageUrl,
      destinationCountry: t.destinationCountry,
      eligibleFields: t.eligibleFields,
      deadlineCountdown: t.deadlineCountdown,
      originalData: t,
    })),
    ...jobApps.map((j): UnifiedApplication => ({
      type: 'job',
      id: j.id,
      title: j.job.title,
      provider: j.job.company,
      status: j.status,
      deadline: j.job.applicationDeadline,
      updatedAt: j.updatedAt,
      linkId: j.job.id,
      imageUrl: j.job.imageUrl,
      destinationCountry: j.job.location,
      eligibleFields: j.job.fieldOfStudy,
      deadlineCountdown: undefined,
      originalData: j,
    })),
  ].sort((a, b) => new Date(b.updatedAt || 0).getTime() - new Date(a.updatedAt || 0).getTime());

  const getFilteredApps = () => {
    return unifiedApplications.filter((app) => {
      // 1. Type filter
      if (typeFilter === 'scholarships' && app.type !== 'scholarship') return false;
      if (typeFilter === 'jobs' && app.type !== 'job') return false;

      // 2. Status filter
      const status = app.status || "RESEARCHING";
      switch (activeTab) {
        case 'in-progress':
          return status === 'RESEARCHING' || status === 'IN_PROGRESS';
        case 'submitted':
          return status === 'SUBMITTED';
        case 'interview':
          return status === 'INTERVIEW';
        case 'awarded':
          return status === 'AWARDED';
        case 'rejected':
          return status === 'REJECTED';
        default:
          return false;
      }
    });
  };

  const getProgress = (status: string) => {
    let base = 0;
    switch(status) {
      case 'RESEARCHING': base = 10; break;
      case 'IN_PROGRESS': base = 30; break;
      case 'SUBMITTED': base = 60; break;
      case 'INTERVIEW': base = 80; break;
      case 'AWARDED': case 'REJECTED': base = 100; break;
    }
    
    if (base === 100) return 100;
    
    const verifiedCount = documents.filter(d => d.verification_status === 'VERIFIED').length;
    let bonus = 0;
    if (verifiedCount === 1) bonus = 10;
    if (verifiedCount >= 2) bonus = 20;
    
    return Math.min(100, base + bonus);
  };

  const getStatusText = (status: string, type: 'job' | 'scholarship') => {
    switch(status) {
      case 'RESEARCHING': return type === 'job' ? 'Draft' : 'Researching';
      case 'IN_PROGRESS': return 'In Progress';
      case 'SUBMITTED': return 'Submitted';
      case 'INTERVIEW': return 'Interview';
      case 'AWARDED': return type === 'job' ? 'Offer' : 'Awarded';
      case 'REJECTED': return 'Rejected';
      default: return 'Draft';
    }
  };

  const getStatusColor = (status: ApplicationTracker['status']) => {
    switch (status) {
      case 'SUBMITTED': return { bg: '#d5e3ff', text: '#001b3c' };
      case 'IN_PROGRESS': return { bg: '#ffdbca', text: '#341100' };
      case 'AWARDED': return { bg: '#a3f69c', text: '#002204' };
      case 'INTERVIEW': return { bg: '#e8e8ed', text: '#1a1c1f' };
      case 'REJECTED': return { bg: '#ffdad6', text: '#93000a' };
      default: return { bg: '#f4f3f8', text: '#43474f' };
    }
  };

  if (loading && unifiedApplications.length === 0) return <Screen scroll={false}><LoadingState /></Screen>;
  if (error && unifiedApplications.length === 0) return <Screen scroll={false}><ErrorState message={(error as Error)?.message || "Failed to load"} onRetry={fetchAll} /></Screen>;

  const filtered = getFilteredApps();

  return (
    <View style={styles.container}>
      {/* Top App Bar */}
      <ImageBackground
        source={require("../../assets/images/header-applications.jpg")}
        style={[styles.header, { paddingTop: insets.top + 10 }]}
        imageStyle={{ resizeMode: "cover" }}
      >
        <View style={[StyleSheet.absoluteFill, { backgroundColor: colors.primary, opacity: 0.65 }]} />
        <View style={styles.headerLeft}>
          <Text style={[styles.headerTitle, { color: '#ffffff' }]}>Application Tracker</Text>
        </View>
        <UserAvatar size={32} style={[styles.avatar, { borderColor: '#ffffff', borderWidth: 1 }]} />
      </ImageBackground>

      {/* Type Filter */}
      <View style={styles.typeFilterWrapper}>
        <View style={styles.typeFilterContainer}>
          {(['all', 'scholarships', 'jobs'] as TypeFilter[]).map(type => (
            <Pressable 
              key={type} 
              style={[styles.typePill, typeFilter === type && styles.typePillActive]} 
              onPress={() => setTypeFilter(type)}
            >
              <Text style={[styles.typePillText, typeFilter === type && styles.typePillTextActive]}>
                {type === 'all' ? 'All' : type.charAt(0).toUpperCase() + type.slice(1)}
              </Text>
            </Pressable>
          ))}
        </View>
      </View>

      {/* Tab Navigation */}
      <View style={styles.tabBarWrapper}>
        <ScrollView horizontal showsHorizontalScrollIndicator={false} contentContainerStyle={styles.tabBar}>
          {(['in-progress', 'submitted', 'interview', 'awarded', 'rejected'] as TabKey[]).map(tab => (
            <Pressable key={tab} style={styles.tabBtn} onPress={() => setActiveTab(tab)}>
              <Text style={[styles.tabBtnText, activeTab === tab && styles.tabBtnTextActive]}>
                {tab === 'in-progress' ? 'In Progress' : tab.charAt(0).toUpperCase() + tab.slice(1)}
              </Text>
              {activeTab === tab && <View style={styles.activeTabIndicator} />}
            </Pressable>
          ))}
        </ScrollView>
      </View>

      {/* Content */}
      <ScrollView contentContainerStyle={styles.contentContainer} showsVerticalScrollIndicator={false}>
        {filtered.length === 0 ? (
          <View style={styles.emptyCard}>
            <Ionicons name="folder-open-outline" size={48} color={colors.muted} style={{ marginBottom: 8 }} />
            <Text style={styles.emptyTitle}>Nothing here yet</Text>
            <Text style={styles.emptyText}>Explore jobs and scholarships to add to this list.</Text>
          </View>
        ) : (
          filtered.map(app => {
            const status = app.status || "DRAFT";
            const countdownLabel = app.deadlineCountdown !== undefined ? getCountdownLabel(app.deadlineCountdown) : undefined;
            const statusColor = getStatusColor(status);
            
            // Type Badge
            const typeBadge = (
              <View style={[styles.typeBadge, { backgroundColor: app.type === 'job' ? '#e0f2fe' : '#f3e8ff' }]}>
                <Ionicons name={app.type === 'job' ? 'briefcase' : 'school'} size={12} color={app.type === 'job' ? '#0369a1' : '#7e22ce'} />
                <Text style={[styles.typeBadgeText, { color: app.type === 'job' ? '#0369a1' : '#7e22ce' }]}>
                  {app.type === 'job' ? 'Job' : 'Scholarship'}
                </Text>
              </View>
            );

            const statusBadge = (
              <View style={{ flexDirection: 'row', alignItems: 'center', gap: 6 }}>
                {typeBadge}
                <View style={[styles.statusBadge, { backgroundColor: statusColor.bg }]}>
                  <Text style={[styles.statusBadgeText, { color: statusColor.text }]}>
                    {getStatusText(status, app.type).toUpperCase()}
                  </Text>
                </View>
              </View>
            );

            const progressContent = (
              <View style={styles.progressContainer}>
                <View style={styles.progressTextRow}>
                  <Text style={styles.progressPercent}>{getStatusText(status, app.type)}</Text>
                </View>
                <View style={styles.progressBarBg}>
                  <View style={[styles.progressBarFill, { width: `${getProgress(status)}%`, backgroundColor: status === 'REJECTED' ? '#ba1a1a' : (status === 'AWARDED' ? '#1b6d24' : '#003366') }]} />
                </View>
              </View>
            );

            const routeTarget = app.type === 'job' ? `/job-application/${app.id}` : `/application/${app.id}`;

            let actionContent = null;
            if (activeTab === 'awarded') {
              actionContent = (
                <>
                  <View style={styles.congratsBanner}>
                    <Text style={styles.congratsEmoji}>🎉</Text>
                    <View style={{ flex: 1 }}>
                      <Text style={styles.congratsTitle}>Congratulations!</Text>
                      <Text style={styles.congratsText}>You {app.type === 'job' ? 'received an offer for this job' : 'were awarded this scholarship'}.</Text>
                    </View>
                  </View>
                  {progressContent}
                  <Pressable style={styles.btnPrimary} onPress={() => router.push(routeTarget)}>
                    <Text style={styles.btnPrimaryText}>Next Steps</Text>
                  </Pressable>
                </>
              );
            } else if (activeTab === 'interview') {
              actionContent = (
                <>
                  {progressContent}
                  <View style={{ flexDirection: 'row', gap: 8 }}>
                    <Pressable style={[styles.btnPrimary, { flex: 1, backgroundColor: '#ffffff', borderWidth: 1, borderColor: '#003366' }]} onPress={() => router.push(routeTarget)}>
                      <Text style={[styles.btnPrimaryText, { color: '#003366' }]}>View Progress</Text>
                    </Pressable>
                    <Pressable style={[styles.btnPrimary, { flex: 1, backgroundColor: '#003366' }]} onPress={() => router.push("/ai-essay")}>
                      <Ionicons name="hardware-chip" size={20} color="#ffffff" />
                      <Text style={styles.btnPrimaryText}>AI Coach</Text>
                    </Pressable>
                  </View>
                </>
              );
            } else if (activeTab === 'submitted' || activeTab === 'rejected') {
              actionContent = (
                <>
                  <View style={styles.submittedDateBox}>
                    <Ionicons name="calendar-outline" size={18} color={colors.muted} style={{ marginRight: 8 }} />
                    <Text style={styles.submittedDateText}>
                      {status === 'REJECTED' 
                        ? (app.updatedAt ? `Rejected: ${formatDeadline(app.updatedAt)}` : 'Recently updated')
                        : (app.originalData.submittedAt ? `Submitted: ${formatDeadline(app.originalData.submittedAt)}` : (app.originalData.appliedAt ? `Applied: ${formatDeadline(app.originalData.appliedAt)}` : 'Recently updated'))}
                    </Text>
                  </View>
                  {progressContent}
                  <Pressable style={styles.viewDetailsBtn} onPress={() => router.push(routeTarget)}>
                    <Text style={styles.viewDetailsText}>View Progress</Text>
                    <Ionicons name="arrow-forward" size={18} color="#003366" />
                  </Pressable>
                </>
              );
            } else {
              // In Progress
              actionContent = (
                <>
                  {progressContent}
                  <Pressable style={styles.btnPrimary} onPress={() => router.push(routeTarget)}>
                    <Ionicons name="analytics" size={18} color="#ffffff" style={{ marginRight: 8 }} />
                    <Text style={styles.btnPrimaryText}>View Progress</Text>
                  </Pressable>
                </>
              );
            }

            return (
              <BaseScholarshipCard
                key={`${app.type}-${app.id}`}
                title={app.title}
                provider={app.provider}
                deadline={app.deadline ? formatDeadline(app.deadline) : undefined}
                imageUrl={app.imageUrl}
                country={app.destinationCountry}
                field={app.eligibleFields}
                countdownLabel={countdownLabel}
                statusBadge={statusBadge}
                onPress={() => router.push(routeTarget as any)}
              >
                {actionContent}
              </BaseScholarshipCard>
            );
          })
        )}

        {/* Dynamic Empty Content Placeholder */}
        {activeTab === 'in-progress' && filtered.length > 0 && (
          <View style={styles.discoverCard}>
            <Ionicons name="compass" size={64} color="rgba(0, 51, 102, 0.4)" style={{ marginBottom: 8 }} />
            <Text style={styles.discoverTitle}>Discover New Opportunities</Text>
            <Text style={styles.discoverSubtitle}>Based on your profile, we found new matches for you.</Text>
            <Pressable style={styles.exploreBtn} onPress={() => router.push('/(tabs)/scholarships?filter=matches')}>
              <Text style={styles.exploreBtnText}>Explore matches</Text>
              <Ionicons name="arrow-forward" size={16} color="#003366" />
            </Pressable>
          </View>
        )}
      </ScrollView>
    </View>
  );
}

